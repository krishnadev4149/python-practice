num = int(input("enter the number : "))

if  num <= 1 :
    print("enter positive number ( > 0 )")
else :    
    for i in range(2,int(num**0.5)+1) : (* im using here int(num**0.5)+1 cus one factor of √num will be smaller or equal to this   *)
        if num % i == 0 :
            print("not prime")
            break
    else :
        print("prime")
